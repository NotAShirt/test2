<script>
const enterScreen = document.getElementById('enterScreen');
document.getElementById('enterBtn').onclick = () => {
  enterScreen.classList.add('hidden');
};

const pages = [
  document.getElementById('page1'),
  document.getElementById('page2'),
  document.getElementById('page3')
];

let currentPage = 0;

// Initialize pages
pages.forEach((page, index) => {
  page.classList.remove('flip', 'active');
});

pages[0].classList.add('active');

function showPage(index) {
  if (index === currentPage) return;

  // Flip current page away
  pages[currentPage].classList.remove('active');
  pages[currentPage].classList.add('flip');

  // Bring new page forward
  pages[index].classList.remove('flip');
  pages[index].classList.add('active');

  currentPage = index;
}

// Button events
document.getElementById('nextBtn1').addEventListener('click', () => showPage(1));
document.getElementById('nextBtn2').addEventListener('click', () => showPage(2));
document.getElementById('backBtn2').addEventListener('click', () => showPage(0));
document.getElementById('backBtn3').addEventListener('click', () => showPage(1));
</script>
